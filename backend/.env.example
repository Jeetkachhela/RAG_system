GROQ_API_KEY=your_groq_api_key_here
EXCEL_FILE_PATH=../K Apply - Accounts Dump - 18.03.2026 (1).xlsx
CHROMA_DB_DIR=./chroma_db
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=kanan_rag
JWT_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated list of allowed origins for CORS (no * for public deployments)
# Example: https://your-frontend.com,https://www.your-frontend.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false

# Phase 6 (security) placeholders
RATE_LIMIT_PER_MINUTE=60
MAX_BODY_BYTES=200000
WEB_FALLBACK_ENABLED=true
WEB_MAX_RESULTS=5
WEB_MAX_CHARS=4000
REWRITE_CACHE_TTL_SECONDS=300
EMBED_CACHE_TTL_SECONDS=600

# Production guardrails
ENV=development
MAX_MESSAGES=12
MAX_MESSAGE_CHARS=4000
